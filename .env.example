# ==============================================================================
# LLM Provider Configuration
# Options: "gemini" or "openai_compatible"
# ==============================================================================
LLM_PROVIDER=gemini

# --- Option A: Gemini Configuration ---
# Get a key from Google AI Studio (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Option B: OpenAI-Compatible Configuration ---
# Used for DeepSeek, OpenRouter, Qwen Cloud, or local Ollama.
# For local Ollama, use: http://localhost:11434/v1
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL_NAME=deepseek-chat
# If using embeddings from the OpenAI-compatible provider:
OPENAI_EMBEDDING_MODEL_NAME=text-embedding-3-small

# ==============================================================================
# Vector Database Configuration
# Options: "chroma" (local) or "pinecone" (cloud)
# ==============================================================================
VECTOR_DB_TYPE=chroma

# --- Pinecone Cloud Configuration ---
# Get a key and index from Pinecone (free tier available)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=med-consultant
